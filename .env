# Application Settings
NODE_ENV=development
PORT=3002
SERVICE_NAME=appointment-service
LOG_LEVEL=debug

# Database Configuration
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hospital_appointment_db
DB_USER=root
DB_PASSWORD=root

# JWT Configuration
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRY=24h

# API Configuration
API_VERSION=v1
API_PREFIX=/api/v1

# Microservices URLs
PATIENT_SERVICE_URL=http://localhost:3001
DOCTOR_SERVICE_URL=http://localhost:3003

# Logging
LOG_FORMAT=combined
LOG_DIR=./logs

# Server Configuration
REQUEST_TIMEOUT=30000
BODY_LIMIT=10mb

# CORS Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=true
